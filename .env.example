# .env.example — copy to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# Kaggle credentials are read from Kaggle.txt (also gitignored),
# NOT from this file. See README.md § Kaggle credentials.

# PostgreSQL connection
# Homebrew default: system username, no password, localhost:5432
DB_NAME=job_analysis
DB_USER=your_postgres_username
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
